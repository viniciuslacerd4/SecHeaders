# Configuração do Banco de Dados
DATABASE_URL=sqlite+aiosqlite:///./secheaders.db

# ───────────────────────────────────────────
# Configuração do LLM Padrão (OpenRouter)
# ───────────────────────────────────────────
# O LLM padrão é usado quando o usuário NÃO configura sua própria API key.
# Recomendamos usar o OpenRouter com um modelo gratuito para oferecer
# análises com IA sem exigir configuração do usuário final.
#
# Obtenha sua chave gratuita em: https://openrouter.ai/keys
LLM_PROVIDER=openrouter
LLM_API_KEY=your-openrouter-api-key-here
LLM_MODEL=stepfun/step-3.5-flash:free
