# ═══════════════════════════════════════════════
#  SecHeaders — Variáveis de Ambiente (Backend)
# ═══════════════════════════════════════════════

# ── Banco de Dados ──────────────────────────────
# Desenvolvimento (SQLite):
DATABASE_URL=sqlite+aiosqlite:///./data/secheaders.db
# Produção / Render (PostgreSQL) — preenchido automaticamente pelo render.yaml:
# DATABASE_URL=postgresql+asyncpg://user:pass@host:5432/secheaders

# ── LLM Padrão (OpenRouter gratuito) ───────────
# Usado quando o usuário NÃO configura sua própria API key.
# Obtenha sua chave gratuita em: https://openrouter.ai/keys
LLM_PROVIDER=openrouter
LLM_API_KEY=your-openrouter-api-key-here
LLM_MODEL=stepfun/step-3.5-flash:free

# ── CORS (Produção) ────────────────────────────
# URL do frontend em produção (Vercel).
# Sem isso, as requisições do Vercel serão bloqueadas por CORS.
# FRONTEND_URL=https://secheaders.vercel.app

# ── Criptografia ───────────────────────────────
# Chave Fernet para criptografar API keys dos usuários.
# Se não definida, é gerada automaticamente em DATA_DIR/.encryption_key
# ENCRYPTION_KEY=

# ── Diretório de Dados ─────────────────────────
# Onde ficam o banco SQLite e a chave de criptografia (apenas dev/Docker).
# DATA_DIR=./data
