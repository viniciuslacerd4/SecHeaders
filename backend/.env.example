# ═══════════════════════════════════════════════
#  SecHeaders — Variáveis de Ambiente (Backend)
# ═══════════════════════════════════════════════

# ── LLM Padrão (OpenRouter gratuito) ───────────
# Usado para gerar relatórios de segurança com IA.
# Obtenha sua chave gratuita em: https://openrouter.ai/keys
LLM_PROVIDER=openrouter
LLM_API_KEY=your-openrouter-api-key-here
LLM_MODEL=stepfun/step-3.5-flash:free

# ── CORS (Produção) ────────────────────────────
# URL do frontend em produção (Vercel).
# Sem isso, as requisições do Vercel serão bloqueadas por CORS.
# FRONTEND_URL=https://secheaders.vercel.app

# ── API Secret ─────────────────────────────────
# Protege a API contra acessos não autorizados.
# O frontend envia este valor no header X-API-Secret em cada requisição.
# Se não definido, a API aceita qualquer requisição (útil apenas em dev).
# Em produção, gere um valor forte: openssl rand -hex 32
# Deve ser o MESMO valor configurado no frontend (VITE_API_SECRET no Vercel).
API_SECRET=

# ── Diretório de Dados ─────────────────────────
# Onde ficam arquivos de dados temporários (apenas dev/Docker).
# DATA_DIR=./data
